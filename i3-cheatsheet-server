# ── i3 config parser ──────────────────────────────────────────────

def parse_i3_config(config_path=I3_CONFIG):
    """Parse i3 config and extract keybindings with context."""
    bindings = []
    variables = {}

    try:
        with open(config_path, "r") as f:
            lines = f.readlines()
    except FileNotFoundError:
        return [], {}

    current_mode = None
    brace_depth = 0

    for i, line in enumerate(lines):
        stripped = line.strip()

        # Capture variables
        m = re.match(r'^set\s+(\$\w+)\s+(.+)', stripped)
        if m:
            variables[m.group(1)] = m.group(2).strip()

        # Track mode blocks
        mode_match = re.match(r'^mode\s+"([^"]+)"\s*\{', stripped)
        if mode_match:
            current_mode = mode_match.group(1)
            brace_depth = 1
            continue

        if current_mode:
            brace_depth += stripped.count('{') - stripped.count('}')
            if brace_depth <= 0:
                current_mode = None
                continue

        # Capture bindsym lines
        m = re.match(r'^bindsym\s+(.+?)\s+(exec\s+.*|kill|focus\s+\w+|move\s+.*|split\s+\w|fullscreen\s+.*|layout\s+.*|floating\s+.*|sticky\s+.*|border\s+.*|scratchpad\s+.*|workspace\s+.*|mode\s+.*|reload|restart|bar\s+.*|gaps\s+.*|resize\s+.*)', stripped)
        if m:
            keys_raw = m.group(1).strip()
            action_raw = m.group(2).strip()

            # Skip --whole-window mouse bindings
            if '--whole-window' in keys_raw:
                continue

            # Skip Return/Escape exit bindings inside modes (just noise)
            if current_mode and action_raw == 'mode "default"':
                continue

            # Get comment from same line or line above
            comment = ""
            inline_comment = re.search(r'#\s*(.+)$', line)
            if inline_comment:
                comment = inline_comment.group(1).strip()
            elif i > 0:
                prev = lines[i-1].strip()
                if prev.startswith("###") or prev.startswith("# "):
                    comment = prev.lstrip("#").strip().rstrip(":").strip()

            # Add mode context to comment
            if current_mode:
                mode_label = resolve_vars(current_mode, variables)
                # Strip Mod4/Mod1 artifacts from mode labels
                mode_label = mode_label.replace("Super", "").replace("Alt", "").strip()
                if not mode_label:
                    mode_label = current_mode
                mode_prefix = f"[{mode_label}] "
                if comment:
                    comment = mode_prefix + comment
                else:
                    comment = mode_prefix.strip()

            bindings.append({
                "line_num": i,
                "keys_raw": keys_raw,
                "action_raw": action_raw,
                "comment": comment,
                "full_line": stripped,
            })

    return bindings, variables


def resolve_vars(text, variables):
    """Replace variables, longest-first to avoid prefix collisions."""
    result = text
    for var, val in sorted(variables.items(), key=lambda x: -len(x[0])):
        result = result.replace(var, val)
    result = result.replace("Mod4", "Super").replace("Mod1", "Alt")
    return result


def categorize_binding(binding):
    """Assign a category based on the action."""
    action = binding["action_raw"].lower()
    keys = binding["keys_raw"].lower()
    comment = binding["comment"].lower()

    if any(k in keys for k in ["xf86audio"]):
        return "Media & Volume"
    if any(k in keys for k in ["xf86monbrightness"]):
        return "Brightness"
    if "workspace" in action and "move" in action:
        return "Move to Workspace"
    if "workspace" in action:
        return "Workspaces"
    if "focus" in action and "mode_toggle" not in action:
        return "Focus & Navigation"
    if "move" in action:
        return "Move Windows"
    if "exec" in action:
        if any(w in action for w in ["browser", "firefox", "firedragon", "chromium"]):
            return "Applications"
        if any(w in action for w in ["terminal", "kitty", "alacritty"]):
            return "Applications"
        if any(w in action for w in ["rofi", "dmenu"]):
            return "Launcher"
        if any(w in action for w in ["flameshot", "screenshot", "print"]):
            return "Screenshot"
        if any(w in action for w in ["lock", "i3lock"]):
            return "System"
        if any(w in action for w in ["pactl", "pulse", "volume"]):
            return "Media & Volume"
        if any(w in action for w in ["brightness"]):
            return "Brightness"
        if any(w in action for w in ["playerctl"]):
            return "Media & Volume"
        if any(w in action for w in ["shcts", "cheatsheet"]):
            return "Applications"
        return "Applications"
    if "layout" in action or "split" in action:
        return "Layout"
    if "floating" in action or "sticky" in action:
        return "Layout"
    if "fullscreen" in action:
        return "Layout"
    if "kill" in action:
        return "Window Management"
    if "border" in action:
        return "Window Management"
    if "scratchpad" in action:
        return "Scratchpad"
    if "resize" in action:
        return "Resize"
    if "mode" in action:
        return "Modes"
    if "reload" in action or "restart" in action:
        return "System"
    if "bar" in action:
        return "System"
    if "gaps" in action:
        return "Gaps"
    return "Other"


def describe_action(action_raw, variables):
    """Create a human-readable description of the action."""
    action = resolve_vars(action_raw, variables)

    # Common patterns
    if "exec --no-startup-id" in action:
        action = action.replace("exec --no-startup-id ", "")
    if action.startswith("exec "):
        action = action.replace("exec ", "", 1)

    # Clean up trailing ;focus
    action = re.sub(r';focus$', '', action)

    # Trim long paths
    action = action.replace(os.path.expanduser("~"), "~")

    return action.strip()


def get_bindings_json():
    """Return categorized bindings as JSON."""
    bindings, variables = parse_i3_config()
    categorized = {}
    category_order = [
        "Applications", "Launcher", "Screenshot",
        "Focus & Navigation", "Move Windows", "Layout",
        "Window Management", "Scratchpad",
        "Workspaces", "Move to Workspace",
        "Media & Volume", "Brightness",
        "Resize", "Gaps", "Modes", "System", "Other"
    ]

    for b in bindings:
        cat = categorize_binding(b)
        if cat not in categorized:
            categorized[cat] = []

        human_keys = resolve_vars(b["keys_raw"], variables)
        description = describe_action(b["action_raw"], variables)

        categorized[cat].append({
            "line_num": b["line_num"],
            "keys_raw": b["keys_raw"],
            "keys_display": human_keys,
            "action_raw": b["action_raw"],
            "action_display": description,
            "comment": b["comment"],
            "category": cat,
        })

    # Sort categories by defined order
    sorted_cats = []
    for cat in category_order:
        if cat in categorized:
            sorted_cats.append({"name": cat, "bindings": categorized[cat]})
    for cat in categorized:
        if cat not in category_order:
            sorted_cats.append({"name": cat, "bindings": categorized[cat]})

    return sorted_cats


# ── Save handler ──────────────────────────────────────────────────

def save_binding(line_num, new_keys_raw, new_action_raw):
    """Modify a single bindsym line in the i3 config."""
    try:
        with open(I3_CONFIG, "r") as f:
            lines = f.readlines()

        # Backup
        backup = I3_CONFIG + ".bak." + datetime.now().strftime("%Y%m%d_%H%M%S")
        shutil.copy2(I3_CONFIG, backup)

        old_line = lines[line_num]
        # Preserve indentation and any trailing comment
        indent = re.match(r'^(\s*)', old_line).group(1)
        trailing_comment = ""
        tc = re.search(r'\s+(#.+)$', old_line.rstrip('\n'))
        if tc:
            trailing_comment = "  " + tc.group(1)

        new_line = f"{indent}bindsym {new_keys_raw} {new_action_raw}{trailing_comment}\n"
        lines[line_num] = new_line

        with open(I3_CONFIG, "w") as f:
            f.writelines(lines)

        # Reload i3
        subprocess.run(["i3-msg", "reload"], capture_output=True)
        return True, f"Saved. Backup at {backup}"
    except Exception as e:
        return False, str(e)


