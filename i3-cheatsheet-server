  <div class="no-results hidden" id="noResults">
    <span>¯\_(ツ)_/¯</span>
    No bindings match your search.
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
const CATEGORY_META = {
  "Applications":       { icon: "◉", css: "cat-applications" },
  "Launcher":           { icon: "▦", css: "cat-launcher" },
  "Screenshot":         { icon: "◫", css: "cat-screenshot" },
  "Focus & Navigation": { icon: "◇", css: "cat-focus" },
  "Move Windows":       { icon: "⇱", css: "cat-move-win" },
  "Layout":             { icon: "⊞", css: "cat-layout" },
  "Window Management":  { icon: "▣", css: "cat-window" },
  "Scratchpad":         { icon: "▤", css: "cat-scratchpad" },
  "Workspaces":         { icon: "⊡", css: "cat-workspaces" },
  "Move to Workspace":  { icon: "⇥", css: "cat-move-ws" },
  "Media & Volume":     { icon: "♪", css: "cat-media" },
  "Brightness":         { icon: "☀", css: "cat-brightness" },
  "Resize":             { icon: "⤡", css: "cat-resize" },
  "Gaps":               { icon: "⊟", css: "cat-gaps" },
  "Modes":              { icon: "◈", css: "cat-modes" },
  "System":             { icon: "⏻", css: "cat-system" },
  "Other":              { icon: "·", css: "cat-other" },
};

const MODIFIER_KEYS = new Set([
  "super", "alt", "shift", "ctrl", "control", "mod4", "mod1"
]);

const SPECIAL_KEYS = new Set([
  "return", "escape", "space", "tab", "print", "delete", "backspace",
  "left", "right", "up", "down", "plus", "minus",
  "f1","f2","f3","f4","f5","f6","f7","f8","f9","f10","f11","f12",
  "xf86audioraisevolume","xf86audiolowervolume","xf86audiomute",
  "xf86audiomicmute","xf86audionext","xf86audioprev","xf86audioplay",
  "xf86audiostop","xf86monbrightnessup","xf86monbrightnessdown"
]);

let allCategories = [];
let activeFilter = null;

// ── Fetch data from server ──
async function loadBindings() {
  try {
    const resp = await fetch('/api/bindings');
    allCategories = await resp.json();
    renderStats();
    renderAll();
  } catch (e) {
    document.getElementById('content').innerHTML =
      '<div class="no-results"><span>⚠</span>Failed to load bindings from server.</div>';
  }
}

// ── Render stats/filter chips ──
function renderStats() {
  const bar = document.getElementById('statsBar');
  const totalCount = allCategories.reduce((s, c) => s + c.bindings.length, 0);

  let html = `<div class="stat-chip ${!activeFilter ? 'active' : ''}" data-filter="">All <span class="count">${totalCount}</span></div>`;
  for (const cat of allCategories) {
    const meta = CATEGORY_META[cat.name] || CATEGORY_META["Other"];
    const isActive = activeFilter === cat.name;
    html += `<div class="stat-chip ${isActive ? 'active' : ''}" data-filter="${cat.name}">${cat.name} <span class="count">${cat.bindings.length}</span></div>`;
  }
  bar.innerHTML = html;

  bar.querySelectorAll('.stat-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const f = chip.dataset.filter;
      activeFilter = f || null;
      renderStats();
      renderAll();
    });
  });
}

// ── Render all categories ──
function renderAll() {
  const query = document.getElementById('search').value.toLowerCase().trim();
  const content = document.getElementById('content');
  const noResults = document.getElementById('noResults');
  let html = '';
  let anyVisible = false;

  // Keep noResults in DOM
  for (const cat of allCategories) {
    if (activeFilter && cat.name !== activeFilter) continue;

    const meta = CATEGORY_META[cat.name] || CATEGORY_META["Other"];
    const filtered = cat.bindings.filter(b => {
      if (!query) return true;
      const hay = (b.keys_display + ' ' + b.action_display + ' ' + b.comment + ' ' + b.keys_raw + ' ' + b.action_raw).toLowerCase();
      return hay.includes(query);
    });

    if (filtered.length === 0) continue;
    anyVisible = true;

    html += `<div class="category ${meta.css}">`;
    html += `<div class="category-header">
      <div class="category-icon">${meta.icon}</div>
      <div class="category-name">${cat.name}</div>
      <div class="category-count">${filtered.length}</div>
    </div>`;

    for (const b of filtered) {
      html += renderBinding(b);
    }
    html += `</div>`;
  }

  // Rebuild content but keep noResults
  content.innerHTML = html + '<div class="no-results hidden" id="noResults"><span>¯\\_(ツ)_/¯</span>No bindings match your search.</div>';

  if (!anyVisible) {
    document.getElementById('noResults').classList.remove('hidden');
  }
}

// ── Render one binding row ──
function renderBinding(b) {
  const keysHtml = renderKeys(b.keys_display);
  const actionHtml = renderAction(b);

  return `<div class="binding-row" data-line="${b.line_num}" id="row-${b.line_num}">
    <div class="keys">${keysHtml}</div>
    <div class="action-text">${actionHtml}</div>
    <button class="edit-btn" onclick="startEdit(${b.line_num})">edit</button>
  </div>`;
}

// ── Render key combination ──
function renderKeys(display) {
  const parts = display.split('+');
  return parts.map((p, i) => {
    const clean = p.trim();
    const lower = clean.toLowerCase();
    let cls = 'key';
    if (MODIFIER_KEYS.has(lower)) cls += ' mod';
    else if (SPECIAL_KEYS.has(lower)) cls += ' special';
    const sep = i < parts.length - 1 ? '<span class="key-sep">+</span>' : '';
    return `<span class="${cls}">${clean}</span>${sep}`;
  }).join('');
}

// ── Render action with comment ──
function renderAction(b) {
  let text = '';
  if (b.comment) {
    text += `<span class="comment-tag">${escHtml(b.comment)}</span> — `;
  }
  text += `<span class="cmd">${escHtml(b.action_display)}</span>`;
  return text;
}

// ── Edit mode ──
function startEdit(lineNum) {
  // Find the binding
  let binding = null;
  for (const cat of allCategories) {
    binding = cat.bindings.find(b => b.line_num === lineNum);
    if (binding) break;
  }
  if (!binding) return;

  const row = document.getElementById(`row-${lineNum}`);
  row.classList.add('editing');
  row.innerHTML = `
    <div style="grid-column:1/-1;">
      <div class="keys">${renderKeys(binding.keys_display)}</div>
      <div class="edit-form">
        <div>
          <label>Keys (raw i3 syntax)</label>
          <input type="text" id="edit-keys-${lineNum}" value="${escAttr(binding.keys_raw)}">
        </div>
        <div>
          <label>Action</label>
          <input type="text" id="edit-action-${lineNum}" value="${escAttr(binding.action_raw)}">
        </div>
        <div class="edit-actions">
          <button class="btn btn-cancel" onclick="cancelEdit()">Cancel</button>
          <button class="btn btn-save" onclick="saveEdit(${lineNum})">Save & Reload</button>
        </div>
      </div>
    </div>`;

  document.getElementById(`edit-keys-${lineNum}`).focus();
}

function cancelEdit() {
  renderAll();
}

async function saveEdit(lineNum) {
  const keysInput = document.getElementById(`edit-keys-${lineNum}`);
  const actionInput = document.getElementById(`edit-action-${lineNum}`);

  if (!keysInput.value.trim() || !actionInput.value.trim()) {
    showToast('Both fields are required.', true);
    return;
  }

  try {
    const resp = await fetch('/api/save', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        line_num: lineNum,
        keys_raw: keysInput.value.trim(),
        action_raw: actionInput.value.trim(),
      }),
    });
    const result = await resp.json();
    if (result.ok) {
      showToast('Saved! i3 config reloaded.');
      await loadBindings();
    } else {
      showToast('Error: ' + result.message, true);
    }
  } catch (e) {
    showToast('Network error: ' + e.message, true);
  }
}

// ── Toast ──
function showToast(msg, isError = false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (isError ? ' error' : '');
  setTimeout(() => { t.className = 'toast'; }, 3000);
}

// ── Utils ──
function escHtml(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escAttr(s) {
  return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── Keyboard shortcuts ──
document.addEventListener('keydown', (e) => {
  if (e.key === '/' && document.activeElement.tagName !== 'INPUT') {
    e.preventDefault();
    document.getElementById('search').focus();
  }
  if (e.key === 'Escape') {
    document.getElementById('search').value = '';
    document.getElementById('search').blur();
    activeFilter = null;
    renderStats();
    renderAll();
  }
});

document.getElementById('search').addEventListener('input', () => renderAll());

// ── Boot ──
loadBindings();
</script>
</body>
</html>'''


# ── HTTP Handler ──────────────────────────────────────────────────

class CheatsheetHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        if self.path == '/' or self.path == '/index.html':
            self.send_response(200)
            self.send_header('Content-Type', 'text/html; charset=utf-8')
            self.end_headers()
            self.wfile.write(get_html().encode('utf-8'))
        elif self.path == '/api/bindings':
            self.send_response(200)
            self.send_header('Content-Type', 'application/json')
            self.end_headers()
            data = get_bindings_json()
            self.wfile.write(json.dumps(data).encode('utf-8'))
        else:
            self.send_error(404)

    def do_POST(self):
        if self.path == '/api/save':
            length = int(self.headers.get('Content-Length', 0))
            body = self.rfile.read(length)
            try:
                data = json.loads(body)
                ok, msg = save_binding(
                    data['line_num'],
                    data['keys_raw'],
                    data['action_raw'],
                )
                self.send_response(200)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(json.dumps({"ok": ok, "message": msg}).encode('utf-8'))
            except Exception as e:
                self.send_response(500)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(json.dumps({"ok": False, "message": str(e)}).encode('utf-8'))
        else:
            self.send_error(404)

    def log_message(self, fmt, *args):
        pass  # suppress console spam


# ── Main ──────────────────────────────────────────────────────────

if __name__ == '__main__':
    import argparse
    parser = argparse.ArgumentParser(description='i3 keybinding cheatsheet server')
    parser.add_argument('--expose', action='store_true',
                        help='Listen on all interfaces (0.0.0.0) for Tailscale/LAN access. '
                             'Default is localhost only (127.0.0.1).')
    args = parser.parse_args()

    bind = '0.0.0.0' if args.expose else '127.0.0.1'
    server = http.server.HTTPServer((bind, PORT), CheatsheetHandler)
    print(f"i3 cheatsheet server running on http://{bind}:{PORT}")
    if args.expose:
        print("  ⚠  Exposed on all interfaces — make sure you trust your network (e.g. Tailscale)")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nShutting down.")
        server.server_close()
